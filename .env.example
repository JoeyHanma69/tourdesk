# TourDesk AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# Flask
SECRET_KEY=change-me-to-something-random
PORT=5000

# ML Model
MODEL_DIR=ml_classifier/model
CONFIDENCE_THRESHOLD=0.65

# AI-generated replies (OPTIONAL)
# Leave USE_AI_REPLIES=false to keep the canned replies — no API key needed.
# Set it to true AND provide a key to have Claude answer routine questions.
USE_AI_REPLIES=false
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
