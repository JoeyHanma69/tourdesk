# TourDesk AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# Flask
SECRET_KEY=change-me-to-something-random
PORT=5000

# ML Model
MODEL_DIR=ml_classifier/model
CONFIDENCE_THRESHOLD=0.65

# AI-generated replies (OPTIONAL)
# Leave USE_AI_REPLIES=false to keep the canned replies — nothing else needed.
# Set it to true and pick a provider below to have the bot answer routine
# questions for real.
USE_AI_REPLIES=false

# Which engine to use: "ollama" (local, free, no key) or "anthropic" (Claude).
AI_PROVIDER=ollama

# --- Ollama (local) — install from https://ollama.com, then `ollama pull llama3.2`
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# --- Anthropic (Claude, cloud) — only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
