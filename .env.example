# TourDesk AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# Flask
SECRET_KEY=change-me-to-something-random
PORT=5000

# WhatsApp Cloud API (from Meta Developer Portal)
WHATSAPP_VERIFY_TOKEN=tourdesk_verify
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_APP_SECRET=

# Staff alert (optional — phone number to send escalation alerts to)
STAFF_ALERT_NUMBER=

# ML Model
MODEL_DIR=ml_classifier/model
CONFIDENCE_THRESHOLD=0.65
